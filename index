    <style>
        .font-instrument-serif { font-family: 'Instrument Serif', serif; font-style: italic; }
        .font-instrument-sans { font-family: 'Instrument Sans', sans-serif; }

        /* --- GLOBAL RESET --- */
        body { 
            background-color: #a200ff !important; 
            margin: 0; 
            padding: 0;
            color: #1a1a1a;
            overflow-x: hidden;
            display: block; 
        }

        /* --- HERO SECTION --- */
        .hero-section {
            min-height: 100vh;
            width: 100%;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: flex-start;
            position: relative;
            padding-top: 7vh;
            margin-bottom: -5vh;
            overflow: visible;
            background-color: #a200ff !important;
        }

        .hero-title {
            text-align: center;
            font-size: 15vw;
            color: #ffffff;
            line-height: 0.85;
            margin: 0;
            text-transform: uppercase;
            font-weight: 900;
            letter-spacing: -0.05em;
            z-index: 10;
            pointer-events: none;
        }

        /* --- FLOATING HEAD --- */
        .floating-head-container {
            position: relative;
            width: 100vw;
            max-width: 1000px;
            aspect-ratio: 1 / 1;
            margin-top: -23vw;
            margin-bottom: -30vh;
            z-index: 20;
            display: flex;
            justify-content: center;
            align-items: center;
            overflow: visible;
        }

        .floating-head-container img.main-head {
            width: 100%;
            height: 100%;
            object-fit: contain;
            animation: float 6s ease-in-out infinite;
        }

        .subheading-container {
            width: 100%;
            text-align: center;
            /* This pulls the text up toward the mascot's chin */
            margin-top: 10vh; 
            /* This adds a little space before the cards start */
            margin-bottom: 40px; 
            z-index: 10;
            position: relative;
        }

.subheading-container h2 {
    font-size: 2.5rem;
    color: #ffffff;
    opacity: 0.9;
    /* This makes it feel more like a caption */
    letter-spacing: -0.02em; 
}

/* Mobile Tweak */
@media (max-width: 768px) {
    .subheading-container {
        margin-top: -2vh;
        padding: 0 20px;
    }
    .subheading-container h2 {
        font-size: 1.5rem;
    }
}

        @keyframes float {
            0%, 100% { transform: translateY(0px) rotate(0deg); }
            50% { transform: translateY(-20px) rotate(2deg); }
        }

        /* --- SHARDS --- */
        .shard { position: absolute; z-index: 25; pointer-events: none; display: flex; justify-content: center; align-items: center; }
        .shard img { width: 100%; height: 100%; object-fit: contain; filter: drop-shadow(0 15px 10px rgba(0,0,0,0.05)); }

        .shard-1 { width: 6vw; top: 30%; left: 15%; animation: float 7s ease-in-out infinite reverse; }
        .shard-2 { width: 12vw; top: 25%; right: 10%; animation: float 5s ease-in-out infinite; }
        .shard-3 { width: 10vw; bottom: 25%; left: 10%; animation: float 8s ease-in-out infinite; }
        .shard-4 { width: 4vw; bottom: 30%; right: 15%; animation: float 9s ease-in-out infinite reverse; }

        /* --- TICKER LOGIC --- */
        .ticker-container {
            width: 100%;
            overflow: hidden;
            position: relative;
            height: 40vh;
            background: #ffffff;
            display: flex;
            align-items: center;
        }

        .ticker-wrapper {
    display: flex;
    gap: 0; /* Remove gap to prevent math errors */
    width: max-content;
    animation: scroll-ticker 25s linear infinite;
    animation-play-state: paused;
}

        .active .ticker-wrapper { animation-play-state: running; }

        .ticker-wrapper img {
    height: 30vh;
    width: auto;
    display: block;
    object-fit: contain;
    flex-shrink: 0;
    /* Move the spacing here instead of 'gap' */
    padding-right: 40px; 
}

        @keyframes scroll-ticker {
            0% { transform: translateX(0); }
            100% { transform: translateX(-50%); }
        }

        /* --- PLAYGROUND SECTION --- */
        .playground-section {
            width: 100%;
            overflow-x: auto; /* Allows horizontal scrolling */
            overflow-y: hidden; /* Prevents vertical shifting */
            scroll-behavior: smooth;
            -webkit-overflow-scrolling: touch;
            padding: 80px 0;
            background-color: #a200ff !important;
        }

        #playground-container { 
            display: flex; 
            height: 75vh; 
            gap: 30px; 
            align-items: stretch;
            width: max-content;
            padding: 0 25vw 0 5vw; 
        }

        /* --- CARD STYLES --- */
        .project-card {
            transition: all 0.7s cubic-bezier(0.19, 1, 0.22, 1);
            width: 120px;
            flex-shrink: 0;
            border: 1px solid #f3f4f6; 
            position: relative; 
            overflow: hidden; 
            border-radius: 8px; 
            background: #fff;
            box-shadow: 0 10px 30px rgba(0, 0, 0, .1);
        }

        .card-image {
            position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover;
            filter: blur(5px) brightness(.7) opacity(.5); transition: filter 0.6s ease;
            pointer-events: none;
        }

        .project-card:hover:not(.active) { width: 180px; cursor: pointer; box-shadow: 0 20px 40px rgba(0, 0, 0, 0.15); }
        .project-card:hover:not(.active) .card-image { filter: blur(0px) brightness(1) opacity(1); }
        
        .project-card.active { width: 80vw; cursor: default; box-shadow: 0 30px 60px rgba(0, 0, 0, 0.12); } 
        .active .card-image { display: none; }

        .project-label { 
            position: absolute; bottom: 30px; left: 30px; 
            font-size: 5rem; transition: opacity 0.3s ease; 
            z-index: 10; pointer-events: none;
            color: #ffffff;
        }
        .active .project-label { opacity: 0; }

        /* SEAMLESS CLOSING TRANSITION */
        .mini-content-window {
            opacity: 0; pointer-events: none; 
            transition: opacity 0.2s ease 0s; /* Disappear instantly on close */
            padding: 60px; display: flex; flex-direction: column; height: 100%; overflow-y: auto;
            width: 80vw; position: relative;
        }
        .active .mini-content-window { 
            opacity: 1; pointer-events: auto; 
            transition: opacity 0.5s ease 0.4s; /* Fade in after card expands */
        }

        .close-project {
            position: absolute; top: 40px; right: 40px;
            cursor: pointer; font-size: 0.75rem; font-weight: bold;
            text-transform: uppercase; letter-spacing: 0.1em;
            color: #9ca3af; z-index: 50;
        }

        /* --- MOBILE --- */
        @media (max-width: 768px) {
            .hero-section { min-height: 60vh !important; padding-top: 3vh; }
            .hero-title { font-size: 15vw; }
            .floating-head-container { width: 90vw; margin-top: -20vw; margin-bottom: -30vh; }
            .shard-1 { width: 12vw; } .shard-2 { width: 18vw; } .shard-3 { width: 14vw; } .shard-4 { width: 10vw; }
            .playground-section { padding-top: 0 !important; }
            .project-card.active { width: 95vw; }
            .mini-content-window { width: 95vw; padding: 30px; }

        }

        /* --- VIDEO MODAL FIX --- */
#video-modal {
    /* 1. This stops it from taking up space in your layout */
    position: fixed; 
    inset: 0; 
    
    /* 2. High z-index keeps it above the mascot and stars */
    z-index: 1000; 
    
    /* 3. This is the magic line that kills the ghost box */
    display: none; 
    
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(10px);
    align-items: center; 
    justify-content: center;
}

/* This is a helper for your JavaScript later */
#video-modal.active {
    display: flex;
}

/* --- RESPONSIVE CORNER LABELS --- */
.hero-label {
    position: absolute;
    z-index: 30;
    color: #ffffff;
    line-height: 1.2;
    pointer-events: none;
    /* This makes the font shrink smoothly as the screen gets smaller */
    font-size: clamp(.7rem, 2.2vw, 3rem);
}

/* TOP LEFT: "a true" */
.label-tl {
    top: 2vh;
    left: 3vw;
}

/* TOP RIGHT: "*mind the glitches*" */
.label-tr {
    top: 33vh;
    right: 3vw;
    text-align: right;
    color: #ffffff;
    text-transform: lowercase;
}

/* BOTTOM LEFT: "Where my creative..." */
.label-bl {
    bottom: 5vh;
    left: 4vw;
    /* Larger clamp for the big subtitle */
    font-size: clamp(1rem, 2.2vw, 3rem);
}

/* BOTTOM RIGHT: "made using..." */
.label-br {
    bottom: 5vh;
    right: 4vw;
    text-align: right;
    color: #ffffff;
}

/* MOBILE FIX: On small phones, we nudge them in slightly */
@media (max-width: 768px) {
    .hero-label { padding: 0 10px; }
    .label-bl { bottom: 2vh; }
}

/* --- LINK BUTTON CONTAINER --- */
.hero-link-container {
    position: absolute;
    /* This anchors it to the same bottom-right "safety zone" as the text */
    bottom: calc(6vh + 50px); /* 30px is a guess, adjust this to create perfect spacing */
    right: 14vw;
    z-index: 30;
    pointer-events: auto; /* Makes sure the button is actually clickable! */
    width: clamp(1rem, 2.2vw, 3rem); /* Matches the text size */
}

/* --- BUTTON STYLING --- */
.hero-button {
    display: inline-block;
    padding: 10px 20px;
    background: transparent;
    color: #ffffff;
    border: 1px solid #ffffff;
    border-radius: 4px; /* A very subtle curve */
    font-size: 0.75rem; /* Matches your other 'sans' labels */
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    text-decoration: none;
    transition: all 0.3s ease;
    cursor: pointer;
    white-space: nowrap; /* Prevents text from breaking onto two lines */
}

/* --- HOVER EFFECT --- */
.hero-button:hover {
    background: #ffffff;
    color: #1a1a1a;
    box-shadow: 0 5px 25px rgba(255, 255, 255, 0.4); /* A subtle "glitch glow" */
    transform: translateY(-2px); /* Slight lift */
}

/* --- MOBILE TWEAKS --- */
@media (max-width: 768px) {
    .hero-link-container {
        /* We stack it on phones for better balance */
        bottom: 8vh;
        right: 50%;
        transform: translateX(50%);
        text-align: center;
    }
    .hero-button {
        padding: 8px 18px;
        font-size: 0.65rem;
    }
}

    </style>
